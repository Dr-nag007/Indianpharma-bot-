# ============================================================================
# ENVIRONMENT CONFIGURATION FOR INDIAN PHARMA RAG SYSTEM
# ============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit the actual .env file to version control!
# ============================================================================

# ============================================================================
# OPENAI CONFIGURATION - REQUIRED
# ============================================================================

# OpenAI API Key - Get from https://platform.openai.com/api-keys
# Used for generating embeddings and LLM responses
OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding Model - Which OpenAI embedding model to use
# Options: 
#   - text-embedding-3-small (fast, cheap, 1536 dims) - RECOMMENDED
#   - text-embedding-3-large (slower, accurate, 3072 dims)
EMBEDDING_MODEL=text-embedding-3-small

# LLM Model - Which GPT model to use for generating answers
# Options:
#   - gpt-3.5-turbo (fast, cheap) - RECOMMENDED for production
#   - gpt-4 (slower, more capable but expensive)
LLM_MODEL=gpt-3.5-turbo

# LLM Parameters
LLM_TEMPERATURE=0.3           # Lower = more deterministic, Higher = more creative
LLM_MAX_TOKENS=1024           # Maximum response length

# ============================================================================
# PINECONE CONFIGURATION - REQUIRED
# ============================================================================

# Pinecone API Key - Get from https://www.pinecone.io (free tier available)
# Used for storing and retrieving drug embeddings
PINECONE_API_KEY=pcak_your-pinecone-api-key-here

# Pinecone Index Name - Name of the vector database index
# Will be created automatically if it doesn't exist
PINECONE_INDEX_NAME=indian-pharma-index

# Pinecone Namespace - Partition within the index
# Allows storing multiple datasets in one index
PINECONE_NAMESPACE=drug-data

# Metric for similarity - Type of distance metric
# Options: cosine (recommended), euclidean, dotproduct
PINECONE_METRIC=cosine

# ============================================================================
# RAG PIPELINE CONFIGURATION
# ============================================================================

# Chunking Configuration - How to split documents
CHUNK_SIZE=500                # Characters per chunk (bigger = more context)
CHUNK_OVERLAP=50              # Overlap between chunks (prevents info loss)

# Retrieval Configuration
TOP_K=5                        # Number of documents to retrieve per query
SIMILARITY_THRESHOLD=0.5       # Minimum similarity score (0-1) to include result

# Batch Processing - For efficient bulk operations
BATCH_SIZE=32                  # Documents per batch for embeddings
RATE_LIMIT=60                  # API requests per minute

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log Level - Controls verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Environment Type
# Options: development, staging, production
ENVIRONMENT=development

# Debug Mode - Enable detailed error messages
# Set to false in production for security
DEBUG=true

# API Server Configuration
API_HOST=0.0.0.0              # Host to bind to (0.0.0.0 = all interfaces)
API_PORT=8000                 # Port to run on
API_WORKERS=4                 # Number of worker processes (for production)

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

# Project Name
PROJECT_NAME=indian-pharma-rag

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 
# For Railway.app:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Port is automatically assigned by Railway
#
# For Render.com:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Create a Web Service with start command:
#    uvicorn src.api:app --host 0.0.0.0 --port $PORT
#
# For Local Development:
# 1. Copy this file to .env
# 2. Fill in your API keys
# 3. Run: python -m uvicorn src.api:app --reload
#
# ============================================================================
